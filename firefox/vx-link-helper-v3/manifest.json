{
  "manifest_version": 2,
  "name": "VX Link Helper V3",
  "version": "3.0",
  "description": "Copy VX links with tracking cleanup",
  "permissions": [
    "contextMenus",
    "clipboardWrite",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "options_page": "options.html",
"icons": {
  "128": "icon128.png"
},
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.bilibili.com/*",
        "*://*.reddit.com/*",
        "*://*.pixiv.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}