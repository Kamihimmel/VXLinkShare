{
  "manifest_version": 3,
  "name": "VX Link Helper V3",
  "version": "3.0",
  "description": "Copy VX links with tracking cleanup",
  "permissions": [
    "contextMenus",
    "storage",
    "scripting"
  ],
  "host_permissions": [
      "*://*.x.com/*",
      "*://*.twitter.com/*",
      "*://*.bilibili.com/*",
      "*://*.reddit.com/*",
      "*://*.pixiv.net/*"
    ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.bilibili.com/*",
        "*://*.reddit.com/*",
        "*://*.pixiv.net/*"
      ],
      "js": [
        "common.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}